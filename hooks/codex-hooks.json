{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "agent-tts-hook --source codex --event SessionStart",
            "timeout": 30,
            "statusMessage": "Speaking Codex session start"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "agent-tts-hook --source codex --event PermissionRequest",
            "timeout": 30,
            "statusMessage": "Speaking Codex permission request"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agent-tts-hook --source codex --event Stop",
            "timeout": 30,
            "statusMessage": "Speaking Codex stop"
          }
        ]
      }
    ]
  }
}
